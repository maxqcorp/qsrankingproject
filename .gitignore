# Proprietary source data: the QS World University Rankings workbooks are
# copyright QS Quacquarelli Symonds and are NOT redistributed here.
# Obtain them from QS and place them in Dataset/ (see README).
Dataset/

# Derived per-institution data tables (regenerate from the workbooks by
# running the analysis scripts). Figures (*.png) are kept.
analysis/output/*.csv
analysis/output/*.txt

# Python environment, caches, OS and editor cruft
.venv/
venv/
__pycache__/
*.py[cod]
.DS_Store
~$*
.claude/

# Manuscript and cover letters: kept local, not published (code-only repo)
paper/manuscript_docx.md
paper/manuscript.docx
paper/cover_letter.md
paper/cover_letter.docx
paper/cover_letter_v2.md
paper/cover_letter_v2.docx

# Any Word manuscript or template placed in paper/ (e.g. an MDPI submission) stays local
paper/*.docx
paper/*.dot
paper/*.dotx
